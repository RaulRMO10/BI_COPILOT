# ─── Banco de Dados (PostgreSQL / Supabase) ───────────────────────────────────
# Use a URI do SESSION POOLER (porta 5432) com sslmode=require.
# Caracteres especiais da senha devem ser percent-encoded (ex.: ! → %21).
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres?sslmode=require

# ─── LangSmith (opcional — monitoramento de traces) ───────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="YOUR_LANGSMITH_API_KEY"
LANGCHAIN_PROJECT="YOUR_PROJECT_NAME"

# ─── LLM do agente ────────────────────────────────────────────────────────────
# anthropic (default) → Claude Sonnet 5 | openai → GPT (defina LLM_MODEL)
LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-5

# ─── Anthropic (usado quando LLM_PROVIDER=anthropic) ──────────────────────────
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# ─── OpenAI (usado quando LLM_PROVIDER=openai) ────────────────────────────────
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# ─── Cube.js Semantic Layer ───────────────────────────────────────────────────
# Deve ser igual ao CUBEJS_API_SECRET no cube_project/.env
CUBEJS_API_SECRET=YOUR_CUBEJS_API_SECRET
# URL base do Cube.js (local: http://localhost:4000)
CUBE_API_BASE_URL=http://localhost:4000

# ─── Segurança FastAPI ────────────────────────────────────────────────────────
# Token compartilhado com o frontend — gere uma string aleatória forte
IA_FASTAPI_SECRET_TOKEN=YOUR_RANDOM_SECRET_TOKEN

# ─── IDs de departamento (modo demo: 002 público, 004 interno) ───────────────
DEPT_PUBLICO=002
DEPT_EXCLUIDO=004
