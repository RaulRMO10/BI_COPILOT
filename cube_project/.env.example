# ─── Banco de dados (modo demo: Postgres no Supabase) ─────────────────────────
CUBEJS_DB_TYPE=postgres
# Host do SESSION POOLER do Supabase (a conexão direta db.<ref> é IPv6-only)
CUBEJS_DB_HOST=aws-1-us-east-2.pooler.supabase.com
CUBEJS_DB_PORT=5432
CUBEJS_DB_NAME=postgres
# Usuário no formato postgres.<project-ref>
CUBEJS_DB_USER=postgres.YOUR_PROJECT_REF
CUBEJS_DB_PASS=YOUR_DB_PASSWORD
# Supabase exige SSL
CUBEJS_DB_SSL=true

# ─── Cube.js ──────────────────────────────────────────────────────────────────
# Deve ser igual ao CUBEJS_API_SECRET no .env raiz do projeto Python
CUBEJS_API_SECRET=YOUR_CUBEJS_API_SECRET

CUBEJS_WEB_SOCKETS=true
CUBEJS_DEV_MODE=true
CUBEJS_LOG_LEVEL=warn
